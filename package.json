{
  "name": "basalt-landing",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/basalt-ai/mantis.git"
  },
  "scripts": {
    "clean:cache": "node scripts/clean-build-cache.mjs",
    "predev": "node scripts/predev-cache.mjs",
    "dev": "next dev -p 3001",
    "dev:turbo": "next dev --turbo -p 3001",
    "dev:fast": "next dev -p 3001",
    "dev:clean": "node scripts/clean-build-cache.mjs && next dev -p 3001",
    "dev:rescue": "node scripts/clean-build-cache.mjs && next dev -p 3001",
    "figma:export-landing": "node scripts/figma-export-landing.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:vercel": "npm run build && npx --yes --cache ./.npm-cache vercel deploy --prod --yes --scope basalt-ai"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "next": "14.2.18",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "canvas": "^3.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
